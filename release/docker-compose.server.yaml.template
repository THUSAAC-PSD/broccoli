services:
  server:
    image: ${BROCCOLI_SERVER_IMAGE}
    restart: unless-stopped
    ports:
      - "${BROCCOLI_HTTP_BIND:-0.0.0.0:3000}:3000"
    environment:
      BROCCOLI__SERVER__HOST: 0.0.0.0
      BROCCOLI__SERVER__PORT: 3000
      BROCCOLI__SERVER__ID: "${BROCCOLI__SERVER__ID}"
      BROCCOLI__SERVER__FRONTEND_DIST: /srv/dist
      BROCCOLI__SERVER__TRUSTED_PROXIES: "${BROCCOLI__SERVER__TRUSTED_PROXIES:-[]}"
      BROCCOLI__SERVER__RATE_LIMIT_AUTH: "${BROCCOLI__SERVER__RATE_LIMIT_AUTH:-true}"
      BROCCOLI__DATABASE__URL: "${BROCCOLI__DATABASE__URL}"
      BROCCOLI__DATABASE__MAX_CONNECTIONS: "${BROCCOLI__SERVER_DATABASE_MAX_CONNECTIONS:-40}"
      BROCCOLI__MQ__ENABLED: "true"
      BROCCOLI__MQ__URL: "${BROCCOLI__MQ__URL}"
      BROCCOLI__AUTH__JWT_SECRET: "${BROCCOLI__AUTH__JWT_SECRET}"
      BROCCOLI__AUTH__SECURE_COOKIES: "${BROCCOLI__AUTH__SECURE_COOKIES:-false}"
      BROCCOLI__PLUGIN__PLUGINS_DIR: /plugins
      BROCCOLI__STORAGE__BACKEND: "${BROCCOLI__STORAGE__BACKEND:-object_storage}"
      BROCCOLI__STORAGE__DATA_DIR: /data
      BROCCOLI__STORAGE__OBJECT_STORAGE__BUCKET: "${BROCCOLI__STORAGE__OBJECT_STORAGE__BUCKET:-broccoli-blobs}"
      BROCCOLI__STORAGE__OBJECT_STORAGE__REGION: "${BROCCOLI__STORAGE__OBJECT_STORAGE__REGION:-us-east-1}"
      BROCCOLI__STORAGE__OBJECT_STORAGE__ENDPOINT: "${BROCCOLI__STORAGE__OBJECT_STORAGE__ENDPOINT}"
      BROCCOLI__STORAGE__OBJECT_STORAGE__ACCESS_KEY: "${BROCCOLI__STORAGE__OBJECT_STORAGE__ACCESS_KEY}"
      BROCCOLI__STORAGE__OBJECT_STORAGE__SECRET_KEY: "${BROCCOLI__STORAGE__OBJECT_STORAGE__SECRET_KEY}"
      BROCCOLI__STORAGE__OBJECT_STORAGE__PATH_STYLE: "${BROCCOLI__STORAGE__OBJECT_STORAGE__PATH_STYLE:-true}"
      BROCCOLI__SUBMISSION__RATE_LIMIT_PER_MINUTE: "${BROCCOLI__SUBMISSION__RATE_LIMIT_PER_MINUTE:-10000}"
      BROCCOLI__BOOTSTRAP__ADMIN_USERNAME: "${BROCCOLI_BOOTSTRAP_ADMIN_USERNAME:-admin}"
      BROCCOLI__BOOTSTRAP__ADMIN_PASSWORD: "${BROCCOLI_BOOTSTRAP_ADMIN_PASSWORD}"
      BROCCOLI__OBSERVABILITY__LOG_FORMAT: "${BROCCOLI__OBSERVABILITY__LOG_FORMAT:-json}"
      BROCCOLI__OBSERVABILITY__LOG_FILTER: "${BROCCOLI__OBSERVABILITY__LOG_FILTER:-info}"
    volumes:
      - ./plugins:/plugins:ro
      - server_data:/data
    healthcheck:
      test: ["CMD", "/usr/local/bin/broccoli-server", "--healthcheck"]
      interval: 10s
      timeout: 5s
      retries: 20

volumes:
  server_data:
