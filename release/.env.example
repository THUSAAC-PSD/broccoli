# Common image tags. The offline installer rewrites these when it loads images
# from the bundle; registry-based installs can set pinned GHCR/ACR tags.
BROCCOLI_VERSION=v0.3.0
BROCCOLI_SERVER_IMAGE=ghcr.io/thusaac-psd/broccoli/broccoli-server:v0.3.0
# Worker image variants are -icpc, -full, and -base. The interactive
# installer explains the tradeoff and defaults to -icpc.
BROCCOLI_WORKER_IMAGE=ghcr.io/thusaac-psd/broccoli/broccoli-worker:v0.3.0-icpc
POSTGRES_IMAGE=postgres:18-alpine
REDIS_IMAGE=redis:7-alpine
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:4.15
CADDY_IMAGE=caddy:2-alpine

# Shared infra connection strings. Generate these on the infra node, then copy
# the resulting values to server and worker nodes.
BROCCOLI__DATABASE__URL=postgres://postgres:change-me-postgres@10.0.0.10:5432/broccoli
BROCCOLI__MQ__URL=redis://:change-me-redis@10.0.0.10:6379

# Shared blob storage. Use database for simple LAN contests; switch to
# object_storage when you want SeaweedFS/S3.
BROCCOLI__STORAGE__BACKEND=database
BROCCOLI__STORAGE__OBJECT_STORAGE__BUCKET=broccoli-blobs
BROCCOLI__STORAGE__OBJECT_STORAGE__REGION=us-east-1
BROCCOLI__STORAGE__OBJECT_STORAGE__ENDPOINT=http://10.0.0.10:8333
BROCCOLI__STORAGE__OBJECT_STORAGE__ACCESS_KEY=change-me-s3-access
BROCCOLI__STORAGE__OBJECT_STORAGE__SECRET_KEY=change-me-s3-secret
BROCCOLI__STORAGE__OBJECT_STORAGE__PATH_STYLE=true

# Server/auth settings shared by all server replicas.
BROCCOLI__AUTH__JWT_SECRET=change-me-jwt-secret-at-least-32-chars
BROCCOLI__AUTH__SECURE_COOKIES=false
BROCCOLI_BOOTSTRAP_ADMIN_USERNAME=admin
BROCCOLI_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
BROCCOLI__SERVER__TRUSTED_PROXIES=[]
BROCCOLI__SERVER__RATE_LIMIT_AUTH=true
BROCCOLI__SUBMISSION__RATE_LIMIT_PER_MINUTE=10000

# Per-node identities. Override these per server or worker machine.
BROCCOLI__SERVER__ID=server-1
BROCCOLI__WORKER__ID=worker-1

# Role-specific binds.
POSTGRES_BIND=0.0.0.0:5432
REDIS_BIND=0.0.0.0:6379
SEAWEEDFS_S3_BIND=0.0.0.0:8333
SEAWEEDFS_MASTER_BIND=127.0.0.1:9333
BROCCOLI_HTTP_BIND=0.0.0.0:3000
BROCCOLI_GATEWAY_HTTP_BIND=0.0.0.0:80
BROCCOLI_UPSTREAMS='10.0.0.21:3000 10.0.0.22:3000'

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=broccoli
REDIS_PASSWORD=change-me-redis

# Capacity and logging.
BROCCOLI__SERVER_DATABASE_MAX_CONNECTIONS=40
BROCCOLI__WORKER_DATABASE_MAX_CONNECTIONS=5
BROCCOLI__OBSERVABILITY__LOG_FORMAT=json
BROCCOLI__OBSERVABILITY__LOG_FILTER=info
