{
  "name": "@broccoli/plugin-cooldown",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "tsup src/index.tsx --format esm --dts --external react --external @broccoli/web-sdk/api --external @broccoli/web-sdk/i18n",
    "dev": "tsup src/index.tsx --format esm --external react --external @broccoli/web-sdk/api --external @broccoli/web-sdk/i18n --watch --sourcemap"
  },
  "dependencies": {
    "@broccoli/web-sdk": "file:../../../packages/sdk"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.16",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3"
  }
}
