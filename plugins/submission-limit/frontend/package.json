{
  "name": "@broccoli/plugin-submission-limit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "tsdown --dts",
    "dev": "tsdown --watch --sourcemap"
  },
  "tsdown": {
    "entry": [
      "src/index.tsx",
      "src/styles.css"
    ],
    "platform": "neutral",
    "css": {
      "transformer": "postcss",
      "fileName": "styles.css"
    },
    "deps": {
      "neverBundle": [
        "react",
        "@broccoli/web-sdk/api",
        "@broccoli/web-sdk/i18n",
        "@broccoli/web-sdk/ui",
        "@broccoli/web-sdk/utils"
      ]
    }
  },
  "dependencies": {
    "@broccoli/web-sdk": "file:../../../packages/web-sdk"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tsdown/css": "^0.21.4",
    "@types/react": "^19.1.16",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsdown": "^0.21.4",
    "typescript": "~5.9.3"
  }
}
